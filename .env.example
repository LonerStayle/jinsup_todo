# Solo Todo — 환경변수 템플릿
#
# 사용법:
#   1. 이 파일을 `.env.local` 로 복사
#   2. 아래 값을 본인 Supabase / Google Cloud 프로젝트의 실제 값으로 교체
#   3. `flutter run --dart-define-from-file=.env.local` 으로 실행
#   4. 빌드: `flutter build macos --release --dart-define-from-file=.env.local`
#
# `.env.local` 자체는 `.gitignore` 에 포함돼 있어 커밋되지 않습니다.

# --- Supabase ----------------------------------------------------------------
# Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# --- Google OAuth (Calendar 연동) -------------------------------------------
# https://console.cloud.google.com/apis/credentials
# Calendar 연동을 안 쓰실 거면 비워두셔도 됩니다 (앱은 동작합니다).

# Desktop (macOS) 클라이언트 ID
# Type: "Desktop app" (또는 "iOS" 후 bundle id 사용 — Google 권고 변경 추적 필요)
GOOGLE_OAUTH_CLIENT_ID_DESKTOP=

# Android 클라이언트 ID
# Type: "Android" + 패키지명 com.goldenplanet.solo_todo + SHA-1 fingerprint
GOOGLE_OAUTH_CLIENT_ID_ANDROID=
